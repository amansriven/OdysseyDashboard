# Odyssey configuration -- copy this file to `.env` and fill in your own values.
#   cp .env.example .env
# `.env` is gitignored and never committed. This template is safe to commit.
# All values are quoted so the file is valid for both python-dotenv and `source`.

# ---- Google / Vertex AI (serves Gemini) ----
# Option A (recommended on Google Cloud): use Vertex AI.
GOOGLE_GENAI_USE_VERTEXAI="TRUE"
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
GOOGLE_CLOUD_LOCATION="us-central1"

# Option B: use an AI Studio API key instead of Vertex. If you go this route,
# set GOOGLE_GENAI_USE_VERTEXAI="" (blank) and uncomment the key line below.
# GOOGLE_API_KEY="your-ai-studio-api-key"

# ---- MongoDB (Atlas or self-hosted) ----
# Leave MONGO_URI blank to fall back to the local training_data CSVs.
# Atlas connection strings look like the line below -- paste yours, password included.
MONGO_URI="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority"
MONGO_DB="odyssey"
